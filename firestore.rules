rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isRole(role) { return isSignedIn() && getUser().role == role; }
    function isAdmin() { return isRole('admin'); }
    function isTeacher() { return isRole('teacher'); }
    function isStudent() { return isRole('student'); }
    function isOwner(field) { return isSignedIn() && (existing()[field] == request.auth.uid || incoming()[field] == request.auth.uid); }

    // --- CATCH ALL DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
               data.uid == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'teacher', 'student'];
      }

      allow get: if true; // Allow direct lookup for portal functionality
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && (
        incoming().role == 'student' || 
        (incoming().role == 'admin' && request.auth.token.email == 'agmhsspatteeswaram@gmail.com')
      ); 
      allow create: if isAdmin(); // Admin can create any user after being established
      allow update: if (isAdmin() || (isOwner('uid') && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phoneNumber'])));
    }

    // --- CLASSES & SECTIONS ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /sections/{sectionId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // --- ASSIGNMENTS ---
    match /assignments/{assignmentId} {
      function isValidAssignment(data) {
        return data.keys().hasAll(['title', 'dueDate', 'classId', 'sectionId', 'teacherId', 'subject']) &&
               data.title is string && data.title.size() <= 200 &&
               data.teacherId == request.auth.uid;
      }

      allow get: if true;
      allow list: if isSignedIn() && (
        isAdmin() || 
        (isTeacher() && getUser().classId == existing().classId) ||
        (isStudent() && getUser().classId == existing().classId && getUser().sectionId == existing().sectionId)
      );
      allow create: if isTeacher() && isValidAssignment(incoming());
      allow update: if isTeacher() && isOwner('teacherId') && isValidAssignment(incoming());
      allow delete: if isAdmin() || (isTeacher() && isOwner('teacherId'));
    }

    // --- GRADES ---
    match /grades/{gradeId} {
      function isValidGrade(data) {
        return data.keys().hasAll(['studentId', 'subject', 'score', 'maxScore', 'teacherId']) &&
               data.score is number && data.score >= 0 &&
               data.teacherId == request.auth.uid;
      }

      allow read: if isSignedIn() && (
        isAdmin() ||
        isTeacher() ||
        (isStudent() && isOwner('studentId'))
      );
      allow create: if isTeacher() && isValidGrade(incoming());
      allow update: if isTeacher() && isOwner('teacherId') && isValidGrade(incoming());
      allow delete: if isAdmin();
    }

    // --- ANNOUNCEMENTS ---
    match /announcements/{announcementId} {
      allow read: if isSignedIn() && (
        existing().target == 'school' ||
        (getUser().classId == existing().classId && (existing().target == 'class' || getUser().sectionId == existing().sectionId)) ||
        isAdmin()
      );
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || (isTeacher() && isOwner('authorId'));
    }

    // --- MESSAGES ---
    match /messages/{messageId} {
      allow read: if isSignedIn() && (isOwner('senderId') || isOwner('receiverId'));
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }

    // --- PTM ---
    match /ptm/{ptmId} {
      allow read: if isSignedIn() && (isOwner('teacherId') || isOwner('studentId') || isAdmin());
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin() || (isStudent() && isOwner('studentId') && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }
  }
}
